# --- Secrets / credentials: never commit real values ---
# Fill tokens/keys via --set on the helm command line or a local untracked
# file instead of editing the tracked template in place.
*.local.yaml
*.secret.yaml
*.local.md
values-flagd-sync.local.yaml
kubeconfig*
*.kubeconfig
.aws/
.env.local
.env.*.local
*.pem
*.key
*id_rsa*
*.pfx
*.p12
llm-api-key*

# --- Terraform: state and local overrides never get committed ---
**/.terraform/
*.tfstate
*.tfstate.*
*.tfplan
tfplan
crash.log
crash.*.log
**/backend.hcl
**/terraform.tfvars
!**/terraform.tfvars.example

# --- Helm dependency artifacts: regenerate via `helm dependency build` ---
**/charts/*.tgz
**/Chart.lock

# --- OS / editor noise ---
.DS_Store
Thumbs.db
.idea/
.vscode/

infra/tfplan-*

