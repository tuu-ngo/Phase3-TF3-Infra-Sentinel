region       = "ap-southeast-1"
cluster_name = "techx-corp-tf3"

# Deprecated: EKS access is private-only through the SSM bastion.
allowed_admin_cidrs = []

# IAM user/role ARNs of TF3 members who need kubectl/helm access.
eks_admin_principal_arns = [
  "arn:aws:iam::197826770971:user/example-teammate",
]

node_instance_type = "t3.large"
node_desired_size  = 3
node_min_size      = 3
node_max_size      = 6
