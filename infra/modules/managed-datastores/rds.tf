# ── RDS PostgreSQL ────────────────────────────────────────────────────────────

resource "aws_db_subnet_group" "main" {
  name        = "${var.cluster_name}-rds"
  subnet_ids  = var.private_subnet_ids
  description = "Private subnets for ${var.cluster_name} RDS instances"

  tags = {
    Name = "${var.cluster_name}-rds"
  }
}

# RDS parameter group — enforce SSL/TLS connections at the engine level.
# rds.force_ssl = 1 causes PostgreSQL to reject any non-TLS connection.
resource "aws_db_parameter_group" "postgres" {
  name        = "${var.cluster_name}-postgres16"
  family      = "postgres16"
  description = "Force TLS for all connections — ${var.cluster_name}"

  parameter {
    name         = "rds.force_ssl"
    value        = "1"
    apply_method = "immediate"
  }

  tags = {
    Name = "${var.cluster_name}-postgres16"
  }

  lifecycle {
    create_before_destroy = true
  }
}

# Master credentials — Terraform only creates the secret shell; the actual
# username/password is generated by RDS and stored by the managed_master_user_secret
# block. This avoids ever having credentials land in Terraform state.
resource "aws_db_instance" "main" {
  identifier = "${var.cluster_name}-postgres"

  engine            = "postgres"
  engine_version    = var.rds_engine_version
  instance_class    = var.rds_instance_class
  allocated_storage = var.rds_allocated_storage
  storage_type      = "gp3"
  storage_encrypted = true
  kms_key_id        = aws_kms_key.rds.arn

  db_name  = var.rds_db_name
  username = "dbadmin"

  # Let RDS generate and rotate the master password into Secrets Manager.
  # The secret ARN is exposed via managed_master_user_secret[0].secret_arn.
  manage_master_user_password   = true
  master_user_secret_kms_key_id = aws_kms_key.secrets.arn

  multi_az               = var.rds_multi_az
  db_subnet_group_name   = aws_db_subnet_group.main.name
  vpc_security_group_ids = [aws_security_group.rds.id]
  parameter_group_name   = aws_db_parameter_group.postgres.name

  # TLS in-transit: rds.force_ssl in the parameter group enforces it at the
  # engine level; ca_cert_identifier pins the RDS CA cert.
  ca_cert_identifier = "rds-ca-rsa2048-g1"

  backup_retention_period    = var.rds_backup_retention_days
  backup_window              = "03:00-04:00"
  maintenance_window         = "sun:04:00-sun:05:00"
  auto_minor_version_upgrade = true

  deletion_protection = var.rds_deletion_protection

  # Never expose the endpoint on the public internet.
  publicly_accessible = false

  # Emit enhanced monitoring metrics every 60 s.
  monitoring_interval = 60
  monitoring_role_arn = aws_iam_role.rds_monitoring.arn

  skip_final_snapshot       = false
  final_snapshot_identifier = "${var.cluster_name}-postgres-final"

  tags = {
    Name = "${var.cluster_name}-postgres"
  }

  depends_on = [aws_db_parameter_group.postgres]
}

# ── RDS Enhanced Monitoring IAM role ─────────────────────────────────────────

resource "aws_iam_role" "rds_monitoring" {
  name = "${var.cluster_name}-rds-monitoring"

  assume_role_policy = jsonencode({
    Version = "2012-10-17"
    Statement = [{
      Effect    = "Allow"
      Principal = { Service = "monitoring.rds.amazonaws.com" }
      Action    = "sts:AssumeRole"
    }]
  })
}

resource "aws_iam_role_policy_attachment" "rds_monitoring" {
  role       = aws_iam_role.rds_monitoring.name
  policy_arn = "arn:aws:iam::aws:policy/service-role/AmazonRDSEnhancedMonitoringRole"
}
