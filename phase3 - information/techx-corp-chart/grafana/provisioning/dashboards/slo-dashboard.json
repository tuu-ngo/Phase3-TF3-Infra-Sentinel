{
  "title": "TF3 SLO Dashboard",
  "uid": "tf3-slo-v1",
  "description": "TF3 SLO: Browse non-5xx >=99.5% | Browse p95 <1s | Cart >=99.5% | Checkout >=99.0%",
  "editable": true,
  "graphTooltip": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "fiscalYearStartMonth": 0,
  "links": [],
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "🎯 SLO Status — rolling 24h",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "id": 10,
      "title": "Browse — Success Rate (SLO ≥ 99.5%)",
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "webstore-metrics" },
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 1 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showThresholdLabels": true,
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0.98,
          "max": 1,
          "decimals": 4,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 0.990 },
              { "color": "yellow", "value": 0.993 },
              { "color": "green", "value": 0.995 }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "webstore-metrics" },
          "editorMode": "code",
          "expr": "1 - (\n  sum(rate(traces_span_metrics_calls_total{service_name=\"frontend\", status_code=\"STATUS_CODE_ERROR\"}[24h]))\n  /\n  sum(rate(traces_span_metrics_calls_total{service_name=\"frontend\"}[24h]))\n)",
          "legendFormat": "Browse Success Rate",
          "instant": true,
          "refId": "A"
        }
      ]
    },
    {
      "id": 11,
      "title": "Browse — p95 Latency (SLO < 1000ms)",
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "webstore-metrics" },
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 1 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showThresholdLabels": true,
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "min": 0,
          "max": 2000,
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 800 },
              { "color": "orange", "value": 1000 },
              { "color": "red", "value": 1200 }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "webstore-metrics" },
          "editorMode": "code",
          "expr": "histogram_quantile(0.95,\n  sum(rate(traces_span_metrics_duration_milliseconds_bucket{service_name=\"frontend\"}[5m]))\n  by (le)\n)",
          "legendFormat": "p95 latency",
          "instant": true,
          "refId": "A"
        }
      ]
    },
    {
      "id": 12,
