        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "webstore-metrics" },
          "editorMode": "code",
          "expr": "sum(rate(traces_span_metrics_calls_total{service_name=\"frontend\"}[$__rate_interval]))",
