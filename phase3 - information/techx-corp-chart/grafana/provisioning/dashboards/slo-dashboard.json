          "expr": "1 - (sum(rate(traces_span_metrics_calls_total{service_name=\"frontend\", status_code=\"STATUS_CODE_ERROR\"}[$__rate_interval])) / sum(rate(traces_span_metrics_calls_total{service_name=\"frontend\"}[$__rate_interval])))",
